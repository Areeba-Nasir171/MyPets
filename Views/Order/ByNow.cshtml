@model MyPets.Models.Product


@if (TempData["Success"] != null)
{
	<script>
		alert("@TempData["Success"]");
	</script>
}

<div class="container mt-4">


	<h2 class="mb-4">Checkout Page</h2>

	<div class="row">


		<div class="col-md-4">
			<div class="card p-3">


				<img src="@Model.ImageUrl" class="img-fluid mb-3"
					 style="height:330px; object-fit:cover;" />

				<div class="text-center">
					<h5>@Model.Name</h5>
					<p>Price: @Model.Price</p>
				</div>

			</div>
		</div>


		<div class="col-md-8">

			@Html.ValidationSummary(true, "", new { @class = "text-danger" })

			<form method="post" action="/Order/PlaceOrder">
				@Html.AntiForgeryToken()

				<input type="hidden" name="ProductId" value="@Model.Id" />

				<div class="mb-2">
					<label>Name</label>
					<input type="text" name="CustomerName" class="form-control w-75" />
					@Html.ValidationMessage("CustomerName", "", new { @class = "text-danger" })
				</div>

				<div class="mb-2">
					<label>Address</label>
					<input type="text" name="Address" class="form-control w-75" />
				</div>

				<div class="mb-2">
					<label>Phone</label>
					<input type="text" name="Phone" class="form-control w-75" />
				</div>

				<div class="mb-2">
					<label>Quantity</label>
					<input type="number" name="Quantity" class="form-control w-50" value="1" min="1" />
				</div>

				<button type="submit" class="btn btn-primary mt-3">
					Place Order
				</button>

			</form>

		</div>

	</div>

</div>