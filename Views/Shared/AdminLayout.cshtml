<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>@ViewData["Title"] - PetCare Admin</title>
	<link rel="shortcut icon" type="image/png" href="~/admin/images/favicon.png" />
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />



	<!-- Admin CSS -->
	<link rel="stylesheet" href="~/admin/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/admin/css/fontawesome.css" />
	<link rel="stylesheet" href="~/admin/css/styles.min.css" />
	@RenderSection("Styles", required: false)








</head>

<body>

	<!--  Body Wrapper -->
	<div class="page-wrapper" id="main-wrapper" data-layout="vertical" data-navbarbg="skin6" data-sidebartype="full"
		 data-sidebar-position="fixed" data-header-position="fixed">

		<!-- Sidebar Start -->
		<aside class="left-sidebar">
			<!-- Sidebar scroll-->
			<div>

				<div class="brand-logo d-flex align-items-center justify-content-between">
					<h3>
						<a class="text-dark fw-bold text-nowrap text-center d-block py-3 w-100" asp-controller="Home" asp-action="Index">
							<i class="fa-solid fa-paw text-dark me-2"></i> Pet Care
						</a>
					</h3>

					<div class="close-btn d-xl-none d-block sidebartoggler cursor-pointer" id="sidebarCollapse">
						<i class="ti ti-x fs-8"></i>
					</div>
				</div>


				<!-- Sidebar navigation-->
				<nav class="sidebar-nav scroll-sidebar" data-simplebar="">
					<ul id="sidebarnav">

						<li class="nav-small-cap">
							<i class="ti ti-dots nav-small-cap-icon fs-4"></i>
							<span class="hide-menu">MANAGE PETCARE</span>
						</li>

						<li class="sidebar-item">
							<a class="sidebar-link" asp-area="Admin" asp-controller="Products" asp-action="Index">
								<span>
									<i class="ti ti-shopping-cart text-dark"></i>
								</span>
								<span class="hide-menu">Products</span>
							</a>
						</li>

						<li class="sidebar-item">
							<a class="sidebar-link" asp-area="Admin" asp-controller="Order" asp-action="Index">
								<span>
									<i class="ti ti-clipboard-list text-dark"></i>
								</span>
								<span class="hide-menu">Cutomers Order</span>
							</a>
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" asp-area="Admin" asp-controller="PetAdopted" asp-action="Index">
								<span>
									<i class="ti ti-home"></i>
								</span>
								<span class="hide-menu">Manage Pets</span>
							</a>
						</li>



						<li class="sidebar-item">
							<a class="sidebar-link" asp-area="Admin" asp-controller="AdminService" asp-action="Requests">
								<span>
									<i class="ti ti-bath text-dark"></i>
								</span>
								<span class="hide-menu">Services</span>
							</a>
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" asp-area="Admin" asp-controller="AdminFeedBack" asp-action="Feedbacks">
								<span>
									<i class="ti ti-heart text-dark"></i>
								</span>
								<span class="hide-menu">FeedBack</span>
							</a>
						</li>




						<li class="nav-small-cap">
							<i class="ti ti-dots nav-small-cap-icon fs-4"></i>
							<span class="hide-menu">SETTINGS</span>
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" href="/Account/Profile" aria-expanded="false">
								<span>
									<i class="ti ti-user"></i>
								</span>
								<span class="hide-menu">Profile</span>
							</a>
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" href="/Account/Logout" aria-expanded="false">
								<span>
									<i class="ti ti-logout"></i>
								</span>
								<span class="hide-menu">Logout</span>
							</a>
						</li>
					</ul>
				</nav>
				<!-- End Sidebar navigation -->
			</div>
			<!-- End Sidebar scroll-->
		</aside>
		<!--  Sidebar End -->

		<div class="container-fluid">
			@RenderBody()
		</div>







		<div class="body-wrapper">
			<!--  Header Start -->
			<header class="app-header">
				<nav class="navbar navbar-expand-lg navbar-light">
					<ul class="navbar-nav">
						<li class="nav-item d-block d-xl-none">
							<a class="nav-link sidebartoggler nav-icon-hover" id="headerCollapse" href="javascript:void(0)">
								<i class="ti ti-menu-2"></i>
							</a>
						</li>
					</ul>
					<div class="navbar-collapse justify-content-end px-0" id="navbarNav">
						<ul class="navbar-nav flex-row ms-auto align-items-center justify-content-end">
							<li class="nav-item dropdown">

								<div class="dropdown-menu dropdown-menu-end dropdown-menu-animate-up" aria-labelledby="drop2">
									<div class="message-body">
										<a href="/Account/Profile" class="d-flex align-items-center gap-2 dropdown-item">
											<i class="ti ti-user fs-6"></i>
											<p class="mb-0 fs-3">My Profile</p>
										</a>
										<a href="/Account/Settings" class="d-flex align-items-center gap-2 dropdown-item">
											<i class="ti ti-settings fs-6"></i>
											<p class="mb-0 fs-3">Settings</p>
										</a>
										<a href="/Account/Logout" class="btn btn-outline-primary mx-3 mt-2 d-block">Logout</a>
									</div>
								</div>
							</li>
						</ul>
					</div>
				</nav>
			</header>
			<!--  Header End -->


		</div>
	</div>







	<script src="~/admin/js/jquery.min.js"></script>
	<script src="~/admin/js/bootstrap.bundle.min.js"></script>
	<script src="~/admin/js/sidebarmenu.js"></script>
	<script src="~/admin/js/app.min.js"></script>
	<script src="~/admin/js/dashboard.js"></script>





	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

