@{
	ViewData["Title"] = "Gallery";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

@model List<PetAdopt>



<!-- END nav -->
<div class="hero-wrap js-fullheight" style="background-image: url('@Url.Content("~/images/bg_1.jpg")');" data-stellar-background-ratio="0.5">
	<div class="overlay"></div>
	<div class="container">
		<div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center" data-scrollax-parent="true">
			<div class="col-md-11 ftco-animate text-center">
				<h1 class="mb-4">Where Every Pet is Family</h1>
				<h5 style="color: white;">
					See the happy faces of pets who found love and care with us:
				</h5>
			</div>
		</div>
	</div>
</div>








<section class="ftco-section">
	<div class="container">
		<div class="row justify-content-center pb-5 mb-3">
			<div class="col-md-7 heading-section text-center ftco-animate">
				<h2>Pets Gallery</h2>
			</div>
		</div>
		<div class="row">
			@foreach (var item in Model)
			{
				<div class="col-md-4 ftco-animate">
					<div class="work mb-4 img d-flex align-items-end"
						 style="background-image: url('@Url.Content("~/" + item.ImageUrl)');">
						<a href="@Url.Content("~/" + item.ImageUrl)"
						   class="icon image-popup d-flex justify-content-center align-items-center">
							<span class="fa fa-expand"></span>
						</a>
						<div class="desc w-100 px-4">
							<div class="text w-100 mb-3">
								<span>@item.Status</span>
								<h2>@item.PetName</h2>
							</div>
						</div>
					</div>
				</div>
			}
		</div>
	</div>
</section>

