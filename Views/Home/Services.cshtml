@{
	ViewData["Title"] = "Services";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["Success"] != null)
{
	<script>
		alert("@TempData["Success"]");
	</script>
}



<div class="hero-wrap js-fullheight" style="background-image: url('@Url.Content("~/images/bg_1.jpg")');" data-stellar-background-ratio="0.5">
	<div class="overlay"></div>
	<div class="container">
		<div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center" data-scrollax-parent="true">
			<div class="col-md-11 ftco-animate text-center">
				<h1 class="mb-4">Services We Offer</h1>
				<h5 style="color: white;">
					Everything your furry friend needs to stay happy and healthy
				</h5>
			</div>
		</div>
	</div>
</div>




<section class="ftco-section bg-light">
	<div class="container">
		<div class="row justify-content-center pb-5 mb-3">
			<div class="col-md-7 heading-section text-center ftco-animate">
				<h2>Pet Services</h2>
			</div>
		</div>
		<div class="row">
			<!-- Package 1 -->
			<div class="col-md-4 ftco-animate">
				<div class="block-7">
					<div class="img" style="background-image: url('@Url.Content("~/images/pricing.jpg")');"></div>
					<div class="text-center p-4">
						<span class="excerpt d-block">Premium Grooming</span>
						<p>Give your pet a stylish & clean look with professional grooming</p>
						<span class="text-success">Starting from Rs. 500</span>


						<ul class="pricing-text mb-5">
							<li><span class="fa fa-check mr-2"></span>Full Body Professional Grooming</li>
							<li><span class="fa fa-check mr-2"></span>Pet Bath with Herbal Shampoo</li>
							<li><span class="fa fa-check mr-2"></span>Nail Cutting & Ear Cleaning</li>
							<li><span class="fa fa-check mr-2"></span>Fur Styling & Hair Trimming</li>
						</ul>


					</div>
				</div>
			</div>

			<!-- Package 2 -->
			<div class="col-md-4 ftco-animate">
				<div class="block-7">
					<div class="img" style="background-image: url('@Url.Content("~/images/pricing-2.jpg")');"></div>
					<div class="text-center p-4">
						<span class="excerpt d-block">Pet Boarding</span>
						<p>Safe and comfortable home-like stay for your pets.</p>
						<span class="text-success">24/7 Care Available</span>
						<ul class="pricing-text mb-5">
							<li><span class="fa fa-check mr-2"></span>Home-like Comfortable Environment</li>
							<li><span class="fa fa-check mr-2"></span>Daily Feeding & Care Routine</li>
							<li><span class="fa fa-check mr-2"></span>Live CCTV Monitoring Access</li>
							<li><span class="fa fa-check mr-2"></span>Veterinary Support On Call</li>
						</ul>

					</div>
				</div>
			</div>

			<!-- Package 3 -->
			<div class="col-md-4 ftco-animate">
				<div class="block-7">
					<div class="img" style="background-image: url('@Url.Content("~/images/pricing-1.jpg")');"></div>
					<div class="text-center p-4">
						<span class="excerpt d-block">Dog Walking</span>
						<p>Daily walking service to keep your pet active and healthy</p>
						<span class="text-success">Flexible Timing</span>

						<ul class="pricing-text mb-5">
							<li><span class="fa fa-check mr-2"></span>Daily Dog Walking (30 Minutes Walk)</li>
							<li><span class="fa fa-check mr-2"></span>Morning & Evening Walk Service</li>
							<li><span class="fa fa-check mr-2"></span>Group Dog Walking (Social Activity)</li>
							<li><span class="fa fa-check mr-2"></span>Personal Trainer Assisted Walk</li>
						</ul>

					</div>
				</div>
			</div>
		</div>
	</div>
</section>




<section class="ftco-appointment ftco-section ftco-no-pt ftco-no-pb img"
		 style="background-image: url('@Url.Content("~/images/bg_3.jpg")');">
	<div class="overlay"></div>
	<div class="container">
		<div class="row d-md-flex justify-content-end">
			<div class="col-md-12 col-lg-6 half p-3 py-5 pl-lg-5 ftco-animate">
				<h2 class="mb-4">Free Consultation</h2>
				<form class="appointment" method="post" action="/Home/Book">
					@Html.AntiForgeryToken()
					<div class="row">
						<div class="col-md-12">
							<div class="form-group">
								<div class="form-field">
									<div class="select-wrap">
										<div class="icon"><span class="fa fa-chevron-down"></span></div>
										<select name="ServiceType" class="form-control" style="width:500px;">
											<option value="">-- Select Service --</option>
											<option value="Pet Grooming">Pet Grooming</option>
											<option value="Dog Walking">Dog Walking</option>
											<option value="Pet Bath">Pet Bath</option>
											<option value="Training">Training</option>
											<option value="Vet Checkup">Vet Checkup</option>
										</select>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-6">
							<div class="form-group">
								<input type="text" name="PetName" class="form-control" placeholder="Pet Name">
							</div>
						</div>
						<div class="col-md-6">
							<div class="form-group">
								<input type="text" name="OwnerName" class="form-control" placeholder="Owner Name">
							</div>
						</div>
						<div class="col-md-6">
							<div class="form-group">
								<div class="input-wrap">
									<div class="icon"><span class="fa fa-calendar"></span></div>
									<input type="text" name="Date" class="form-control appointment_date" placeholder="Date">
								</div>
							</div>
						</div>
						<div class="col-md-6">
							<div class="form-group">
								<div class="input-wrap">
									<div class="icon"><span class="fa fa-clock-o"></span></div>
									<input type="text" name="Time" class="form-control appointment_time" placeholder="Time">
								</div>
							</div>
						</div>

						<div class="col-md-12">
							<div class="form-group">
								<button type="submit" class="btn btn-dark mt-2">Book Now</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</section>