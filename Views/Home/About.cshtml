@model MyPets.Models.FeedbackVM
@using System.Linq


@{
	ViewData["Title"] = "About";
	Layout = "~/Views/Shared/_Layout.cshtml";
}




<div class="hero-wrap js-fullheight" style="background-image: url('@Url.Content("~/images/bg_1.jpg")');" data-stellar-background-ratio="0.5">
	<div class="overlay"></div>
	<div class="container">
		<div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center" data-scrollax-parent="true">
			<div class="col-md-11 ftco-animate text-center">
				<h1 class="mb-4">About Us</h1>
				<h5 class="mb-4" style="color: white;">We treat every pet like our own family. Learn more about our journey.</h5>

			</div>
		</div>
	</div>
</div>


<section class="ftco-counter">
	<div class="container">
		<div class="row">

			<div class="col-md-11  ftco-animate">
				<div class="text-center">
					<div class="Ostory">
						<h1 class="mb-4" style="color: white; font-weight: bold; ">Our Story</h1>
					</div>
					<div class="text">
						<span>
							PetCare started with a simple mission: to provide the best care for pets who
							are like family. Over the years, we've helped thousands of pets find happiness and health
							through our professional services. From grooming to veterinary care, we've grown from a
							small team to a trusted name in pet care. Our story is written in the wagging tails and
							purring hearts of the pets we serve
						</span>
					</div>
				</div>
			</div>

		</div>
	</div>
</section>




<section class="ftco-section ftco-no-pt ftco-no-pb">
	<div class="container">
		<div class="row d-flex no-gutters">
			<div class="col-md-5 d-flex">
				<div class="img img-video d-flex align-self-stretch align-items-center justify-content-center justify-content-md-center mb-4 mb-sm-0" style="background-image: url('@Url.Content("~/images/about-1.jpg")');">
				</div>
			</div>
			<div class="col-md-7 pl-md-5 py-md-5">
				<div class="heading-section pt-md-5">
					<h2 class="mb-4">Why Choose Us?</h2>
				</div>
				<div class="row">
					<div class="col-md-6 services-2 w-100 d-flex">
						<div class="icon d-flex align-items-center justify-content-center"><span class="flaticon-stethoscope"></span></div>
						<div class="text pl-3">
							<h4>Care Advices</h4>
							<p>Our team provides professional advice on pet nutrition, health, and behavior</p>
						</div>
					</div>
					<div class="col-md-6 services-2 w-100 d-flex">
						<div class="icon d-flex align-items-center justify-content-center"><span class="flaticon-customer-service"></span></div>
						<div class="text pl-3">
							<h4>Customer Supports</h4>
							<p>From booking to after-service care, we guide you at every step</p>
						</div>
					</div>
					<div class="col-md-6 services-2 w-100 d-flex">
						<div class="icon d-flex align-items-center justify-content-center"><span class="flaticon-emergency-call"></span></div>
						<div class="text pl-3">
							<h4>Emergency Services</h4>
							<p> From poisoning to injuries, our emergency unit is prepared for all types of pet emergencies. Just call us!</p>
						</div>
					</div>
					<div class="col-md-6 services-2 w-100 d-flex">
						<div class="icon d-flex align-items-center justify-content-center"><span class="flaticon-veterinarian"></span></div>
						<div class="text pl-3">
							<h4>Veterinary Help</h4>
							<p>Our skilled veterinary team uses advanced technology and proven methods to provide the best medical care</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>


<section class="ftco-section testimony-section" style="background-image: url('@Url.Content("~/images/bg_2.jpg")');">
	<div class="overlay"></div>
	<div class="container">
		<div class="row justify-content-center pb-5 mb-3">
			<div class="col-md-7 heading-section text-center ftco-animate">
				<h2>Happy Clients &amp; Feedbacks</h2>
				
				<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#feedbackModal">
					Give Feedback
				</button>
			</div>
		</div>
		<div class="row ftco-animate">
			<div class="col-md-12">
				<div class="carousel-testimony owl-carousel ftco-owl">
					@foreach (var item in Model.ListData.Where(x => x.IsApproved))
					{
						<!-- Review 1 -->
						<div class="item">
							<div class="testimony-wrap py-4">
								<div class="icon d-flex align-items-center justify-content-center"><span class="fa fa-quote-left"></span></div>
								<div class="text">
									<p class="mb-4">@item.Message</p>
									<div class="d-flex align-items-center">
										<div class="user-img"
											 style="background-image: url('/Image/@(item.ImagePath ?? "default.png")');">
										</div>
										<div class="pl-3">
											<p class="name">@item.Name</p>
											<span class="position">@item.Passion</span>
										</div>
									</div>
								</div>
							</div>
						</div>







					}
				</div>
			</div>
		</div>
	</div>
</section>





<div class="modal fade" id="feedbackModal" tabindex="-1">
	<div class="modal-dialog">
		<div class="modal-content"
			 style="background: linear-gradient(135deg, #28a745, #007bff);
                    color: white;
                    border-radius: 15px;
                    border: none;
                    overflow: hidden;">

			<div class="modal-header" style="border-bottom: none;">
				<h5 class="modal-title">Feedback Form</h5>
				<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
			</div>

			<div class="modal-body">

				<form asp-controller="Feedback" asp-action="Save" method="post" enctype="multipart/form-data">

					@Html.AntiForgeryToken()

					<textarea asp-for="FormData.Message" class="form-control"
							  placeholder="Message"
							  style="border-radius:8px; border:none; padding:10px;"></textarea>
					<span asp-validation-for="FormData.Message" class="text-danger"></span>
					<br>

					<input type="file" name="Image" class="form-control"
						   style="border-radius:8px; border:none; padding:10px;"
						   accept="image/*">
					<br>

					<input asp-for="FormData.Name" class="form-control"
						   placeholder="Name"
						   style="border-radius:8px; border:none; padding:10px;" />
					<span asp-validation-for="FormData.Name" class="text-danger"></span>
					<br>

					<input asp-for="FormData.Passion" class="form-control"
						   placeholder="Your Passion"
						   style="border-radius:8px; border:none; padding:10px;" />
					<span asp-validation-for="FormData.Passion" class="text-danger"></span>
					<br>

					<button type="submit"
							class="btn"
							style="background:white; color:#28a745; font-weight:bold; border:none;">
						Submit
					</button>

				</form>

			</div>

		</div>
	</div>
</div>
